\newlabel{subsec:mixedcubes}{{3.5.3}{60}{\MixedCubes }{subsection.3.5.3}{}}
\newlabel{subsec:mixedcubes@cref}{{[subsection][3][3,5]3.5.3}{[1][60][]60}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.26}{\ignorespaces The \textsc  {MixedCubes}{} architecture. One 3D multiresolution hash encoder covers the spatial coordinates \texttt  {xyz} and three fully dense 2D grids cover the space-time pairs \texttt  {xt}, \texttt  {yt}, and \texttt  {zt}. Dense grids guarantee an exact coordinate-to-feature correspondence with no hash collisions by construction. Features from all four encoders are concatenated and decoded by a shared MLP.}}{60}{figure.caption.49}\protected@file@percent }
\newlabel{fig:mixedcubes_architecture}{{3.26}{60}{The \MixedCubes {} architecture. One 3D multiresolution hash encoder covers the spatial coordinates \texttt {xyz} and three fully dense 2D grids cover the space-time pairs \texttt {xt}, \texttt {yt}, and \texttt {zt}. Dense grids guarantee an exact coordinate-to-feature correspondence with no hash collisions by construction. Features from all four encoders are concatenated and decoded by a shared MLP}{figure.caption.49}{}}
\newlabel{fig:mixedcubes_architecture@cref}{{[figure][26][3]3.26}{[1][60][]60}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.27}{\ignorespaces High-contrast reconstruction slices comparing ground truth, the \textsc  {NeCT}{} baseline, and \textsc  {MixedCubes}{} at an equalised 12-hour training budget.}}{61}{figure.caption.50}\protected@file@percent }
\newlabel{fig:mixedcubes_quality}{{3.27}{61}{High-contrast reconstruction slices comparing ground truth, the \NeCT {} baseline, and \MixedCubes {} at an equalised 12-hour training budget}{figure.caption.50}{}}
\newlabel{fig:mixedcubes_quality@cref}{{[figure][27][3]3.27}{[1][60][]61}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.28}{\ignorespaces PSNR vs.\ epoch for the eight representative \textsc  {MixedCubes}{} configurations shown here. The best-performing configuration (\texttt  {24\_4\_24\_4\_128}, 22.1\,GB) reaches 38.25\,dB PSNR and SSIM 0.940 at epoch~500, 1.78\,dB above the QuadCubes baseline. The lightweight \texttt  {18\_4\_22\_4\_64} (5.1\,GB) reaches 35.96\,dB, nearly matching the baseline at 11\% of its VRAM. Configurations with $F=2$ (the \texttt  {25\_2\_} family) underperform relative to $F=4$ equivalents at comparable VRAM. These eight configurations were selected from a larger experimental set to best illustrate performance across the memory, speed, and quality trade-off space.}}{63}{figure.caption.51}\protected@file@percent }
\newlabel{fig:mixedcubes_epoch}{{3.28}{63}{PSNR vs.\ epoch for the eight representative \MixedCubes {} configurations shown here. The best-performing configuration (\texttt {24\_4\_24\_4\_128}, 22.1\,GB) reaches 38.25\,dB PSNR and SSIM 0.940 at epoch~500, 1.78\,dB above the QuadCubes baseline. The lightweight \texttt {18\_4\_22\_4\_64} (5.1\,GB) reaches 35.96\,dB, nearly matching the baseline at 11\% of its VRAM. Configurations with $F=2$ (the \texttt {25\_2\_} family) underperform relative to $F=4$ equivalents at comparable VRAM. These eight configurations were selected from a larger experimental set to best illustrate performance across the memory, speed, and quality trade-off space}{figure.caption.51}{}}
\newlabel{fig:mixedcubes_epoch@cref}{{[figure][28][3]3.28}{[1][62][]63}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.29}{\ignorespaces PSNR vs.\ wall-clock time for the eight representative \textsc  {MixedCubes}{} configurations. At 24\,h the best configuration (\texttt  {24\_4\_24\_4\_128}, 22.1\,GB) achieves 37.73\,dB PSNR, SSIM 0.936, and MAE 2.0 ($+1.84$\,dB over the baseline). The lightweight \texttt  {18\_4\_22\_4\_64} (5.1\,GB) reaches 35.97\,dB within 0.08\,dB of the baseline at roughly one ninth of the VRAM. The $F=2$ configuration \texttt  {25\_2\_25\_4\_128} (25.5\,GB) reaches only 35.37\,dB at 24\,h, 0.52\,dB below the baseline despite its large hashmap, confirming that $F=2$ is counterproductive in the split-encoder context. These configurations were selected to best represent the experimental landscape.}}{64}{figure.caption.52}\protected@file@percent }
\newlabel{fig:mixedcubes_time}{{3.29}{64}{PSNR vs.\ wall-clock time for the eight representative \MixedCubes {} configurations. At 24\,h the best configuration (\texttt {24\_4\_24\_4\_128}, 22.1\,GB) achieves 37.73\,dB PSNR, SSIM 0.936, and MAE 2.0 ($+1.84$\,dB over the baseline). The lightweight \texttt {18\_4\_22\_4\_64} (5.1\,GB) reaches 35.97\,dB within 0.08\,dB of the baseline at roughly one ninth of the VRAM. The $F=2$ configuration \texttt {25\_2\_25\_4\_128} (25.5\,GB) reaches only 35.37\,dB at 24\,h, 0.52\,dB below the baseline despite its large hashmap, confirming that $F=2$ is counterproductive in the split-encoder context. These configurations were selected to best represent the experimental landscape}{figure.caption.52}{}}
\newlabel{fig:mixedcubes_time@cref}{{[figure][29][3]3.29}{[1][62][]64}{}{}{}}
